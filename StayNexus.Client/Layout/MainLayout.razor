@inherits LayoutComponentBase

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudText Typo="Typo.h6" Class="ml-3">StayNexus</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudText Class="mr-3">@context.User.Identity?.Name</MudText>
                <MudButton Color="Color.Inherit" Href="/logout">Logout</MudButton>
            </Authorized>
            <NotAuthorized>
                <MudButton Color="Color.Inherit" Href="/login">Login</MudButton>
                <MudButton Color="Color.Inherit" Href="/register">Register</MudButton>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer Open="true" Variant="DrawerVariant.Mini" Elevation="2">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>